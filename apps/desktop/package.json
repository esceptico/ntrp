{
  "name": "ntrp-desktop",
  "version": "1.0.0-rc.3",
  "private": true,
  "description": "ntrp desktop client",
  "main": "electron/main.cjs",
  "type": "module",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "start": "electron .",
    "dist": "vite build && electron-builder",
    "dist:mac": "vite build && electron-builder --mac",
    "dist:mac:arm64": "vite build && electron-builder --mac --arm64",
    "dist:mac:x64": "vite build && electron-builder --mac --x64",
    "dist:win": "vite build && electron-builder --win",
    "dist:linux": "vite build && electron-builder --linux"
  },
  "packageManager": "bun@1.3.10",
  "engines": {
    "bun": ">=1.3.10",
    "node": ">=22"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.0.0",
    "electron": "^39.2.7",
    "electron-builder": "^26.8.1",
    "tailwindcss": "^4.2.4",
    "typescript": "latest",
    "vite": "^7.2.7"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "highlight.js": "^11.11.1",
    "katex": "^0.16.45",
    "liquid-glass-react": "^1.1.1",
    "lucide-react": "^1.14.0",
    "mermaid": "^11.14.0",
    "motion": "^12.38.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "rehype-katex": "^7.0.1",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "use-stick-to-bottom": "^1.1.4",
    "zustand": "^5.0.12"
  },
  "build": {
    "appId": "com.ntrp.desktop",
    "productName": "ntrp",
    "copyright": "Copyright © ntrp",
    "directories": {
      "output": "release",
      "buildResources": "electron/icons"
    },
    "files": [
      "dist/renderer/**/*",
      "electron/**/*",
      "package.json",
      "!**/*.map",
      "!**/.DS_Store"
    ],
    "asar": true,
    "extraMetadata": {
      "main": "electron/main.cjs"
    },
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "electron/icons/icon.png",
      "target": [
        {
          "target": "dmg",
          "arch": ["arm64", "x64"]
        },
        {
          "target": "zip",
          "arch": ["arm64", "x64"]
        }
      ],
      "darkModeSupport": true,
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "identity": null
    },
    "dmg": {
      "title": "ntrp ${version}",
      "writeUpdateInfo": false,
      "contents": [
        {
          "x": 130,
          "y": 200,
          "type": "file"
        },
        {
          "x": 420,
          "y": 200,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "win": {
      "icon": "electron/icons/icon.png",
      "target": ["nsis"]
    },
    "linux": {
      "icon": "electron/icons/icon.png",
      "target": ["AppImage"],
      "category": "Office"
    }
  }
}
