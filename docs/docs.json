{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "ntrp",
  "colors": {
    "primary": "#64748B",
    "light": "#94A3B8",
    "dark": "#475569"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting Started",
            "pages": [
              "index",
              "quickstart",
              "guides/tui"
            ]
          },
          {
            "group": "Features",
            "pages": [
              "guides/memory",
              "guides/automations",
              "guides/tools",
              "guides/skills"
            ]
          },
          {
            "group": "Integrations",
            "pages": [
              "integrations/models",
              "integrations/gmail",
              "integrations/calendar",
              "integrations/obsidian",
              "integrations/browser"
            ]
          },
          {
            "group": "Reference",
            "pages": [
              "configuration"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "api-reference/introduction",
              "api-reference/authentication",
              "api-reference/streaming"
            ]
          },
          {
            "group": "Endpoints",
            "pages": [
              "api-reference/chat",
              "api-reference/sessions",
              "api-reference/memory",
              "api-reference/automations",
              "api-reference/config"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "GitHub",
          "href": "https://github.com/esceptico/ntrp",
          "icon": "github"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "primary": {
      "type": "button",
      "label": "Get Started",
      "href": "/quickstart"
    }
  },
  "contextual": {
    "options": ["copy", "view", "chatgpt", "claude"]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/esceptico/ntrp"
    }
  }
}
